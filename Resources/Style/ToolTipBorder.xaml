<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    
    <Style TargetType="ToolTip">
        <Setter Property="ToolTipService.Placement" Value="Mouse"/>
        <Setter Property="ToolTipService.HorizontalOffset" Value="6"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="18"/>
        <Setter Property="ToolTipService.HasDropShadow" Value="false"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="30"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip" >
                    <Border Background="{DynamicResource BgLight}"
                            BorderBrush="{DynamicResource BgDark}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="5,3">
                        <ContentPresenter HorizontalAlignment="Left" 
                                        VerticalAlignment="Center"
                                        TextBlock.FontFamily="{DynamicResource FontLight}"
                                        TextBlock.Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>