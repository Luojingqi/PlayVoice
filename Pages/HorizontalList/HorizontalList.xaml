<UserControl x:Class="PlayVoice.Pages.HorizontalList.HorizontalList"
                x:Name="self"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:local="clr-namespace:PlayVoice.Pages.HorizontalList"
                xmlns:pages="clr-namespace:PlayVoice.Pages"
                mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="{Binding Margin, ElementName=self}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding Header, ElementName=self}" 
                Style="{StaticResource TextBlockLight}"
                VerticalAlignment="Center" 
                Margin="13.5,0,0,0" 
                FontSize="{Binding TextBlockFontSize, ElementName=self}" 
                HorizontalAlignment="Left"
                TextAlignment="Left"
                Grid.Column="0"/>

        <ListBox x:Name="listBox"
                Style="{StaticResource TransparentListBoxStyle}"
                ItemsSource="{Binding ItemsSource, ElementName=self}"
                DisplayMemberPath="{Binding DisplayMemberPath, ElementName=self}"
                SelectedValuePath="{Binding SelectedValuePath, ElementName=self}"
                SelectedItem="{Binding SelectedItem, ElementName=self}"
                SelectedIndex="{Binding SelectedIndex, ElementName=self, Mode=TwoWay}"
                SelectedValue="{Binding SelectedValue, ElementName=self}"
                Width="{Binding DropDownWidth, ElementName=self}"
                FontSize="{Binding ListBoxFontSize, ElementName=self}"
                ToolTip="{Binding ToolTipText, ElementName=self}"
                pages:LabelStatusHelper.LabelStatus="{Binding LabelStatus, ElementName=self}"
                Grid.Column="1"
                HorizontalAlignment="Right"
                SelectionMode="{Binding SelectionMode,ElementName=self}"/>
    </Grid>
</UserControl>
