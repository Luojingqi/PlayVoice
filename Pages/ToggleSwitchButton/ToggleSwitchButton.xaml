<UserControl x:Class="PlayVoice.Pages.ToggleSwitchButton.ToggleSwitchButton"
             x:Name="self"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlayVoice.Pages.ToggleSwitchButton"
             xmlns:pages="clr-namespace:PlayVoice.Pages"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ComboBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Button.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="{Binding Padding, ElementName=self}">
        <Grid Margin="{Binding Margin, ElementName=self}">
            <!--Opacity淡化颜色-->
            <Border CornerRadius="3.5" Opacity="0.125">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LabelStatus, ElementName=self}" Value="Error">
                                <Setter Property="Background" Value="{DynamicResource Error}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LabelStatus, ElementName=self}" Value="Warning">
                                <Setter Property="Background" Value="{DynamicResource Warning}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LabelStatus, ElementName=self}" Value="Success">
                                <Setter Property="Background" Value="{DynamicResource Success}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Header, ElementName=self}" 
                    Style="{StaticResource TextBlockLight}"
                    VerticalAlignment="Center" 
                    Margin="13.5,0,0,0" 
                    FontSize="{Binding TextBlockFontSize, ElementName=self}" 
                    HorizontalAlignment="Left"
                    TextAlignment="Left"
                    Grid.Column="0"/>

                <ToggleButton x:Name="toggleButton"
                    Style="{StaticResource ToggleSwitchStyle}"
                    Grid.Column="1"
                    Width="{Binding ButtonWidth, ElementName=self}"
                    IsChecked="{Binding IsChecked, ElementName=self, Mode=TwoWay}"
                    HorizontalAlignment="Right"
                    Margin="0,3.5,20,3.5"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>