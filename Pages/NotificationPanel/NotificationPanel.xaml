<UserControl x:Class="PlayVoice.Pages.NotificationPanel.NotificationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlayVoice.Pages.NotificationPanel"
             xmlns:pages="clr-namespace:PlayVoice.Pages"
             mc:Ignorable="d">

    <UserControl.Resources>
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut"/>
        <QuadraticEase x:Key="EaseInQuad" EasingMode="EaseIn"/>
    </UserControl.Resources>

    <ItemsControl x:Name="Panel"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,20,20"
                  ItemsSource="{Binding NotificationItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  KeyboardNavigation.TabNavigation="None">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel VerticalAlignment="Bottom"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Grid>
                    <!-- 通知卡片（主体） -->
                    <Border x:Name="NotifyBorder"
                            Width="300"
                            MinHeight="80"
                            Margin="0,0,0,4"
                            Background="{DynamicResource BgMedium}"
                            CornerRadius="10"
                            BorderBrush="{DynamicResource AccentColor}"
                            BorderThickness="1"
                            Opacity="0"
                            RenderTransformOrigin="1,1"
                            pages:LabelStatusHelper.LabelStatus="{Binding Status}"
                            MouseEnter="NotifyBorder_MouseEnter"
                            MouseLeave="NotifyBorder_MouseLeave">
                        <Border.RenderTransform>
                            <TranslateTransform X="320" Y="0"/>
                        </Border.RenderTransform>

                        <!-- 进入动画：右侧滑入 + 淡入 -->
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="NotifyBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="320" To="0" Duration="0:0:0.35"
                                                         EasingFunction="{StaticResource EaseOutQuad}"/>
                                        <DoubleAnimation Storyboard.TargetName="NotifyBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 状态点 + 标题 + 关闭按钮 -->
                            <Grid Grid.Row="0" Margin="10,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 状态指示点 -->
                                <Grid Grid.Column="0" Margin="0,2,0,0" VerticalAlignment="Center">
                                    <!-- 外侧大圆：-->
                                    <Ellipse Width="14" Height="14"
                                             Fill="{DynamicResource AccentColor}"
                                             Opacity="0.325"
                                             x:Name="GlowEllipse"/>
                                    <!-- 内侧小圆：-->
                                    <Ellipse Width="9" Height="9"
                                             Fill="{DynamicResource AccentColor}"
                                             Opacity="0.825"
                                             x:Name="CoreEllipse"/>
                                </Grid>

                                <TextBlock Margin="10,3,10,0"
                                           Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentColor}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>

                                <!-- 关闭按钮 -->
                                <Button Margin="0,0,0,0"
                                        Grid.Column="2"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Right"
                                        Content="∨"
                                        FontSize="15"
                                        Width="38" Height="26"
                                        Click="NotificationClose_Click"
                                        Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BgLight}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 消息内容 -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Message}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="16,2,10,2"
                                           VerticalAlignment="Top"/>

                                <!-- 进度条（紧贴卡片下边框） -->
                                <Border Grid.Row="1"
                                        x:Name="ProgressBarBorder"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Background="Transparent"
                                        Margin="0,0,0,0"
                                        Height="4"
                                        CornerRadius="0,0,10,10"
                                        ClipToBounds="True"
                                        Width="{Binding ElementName=NotifyBorder, Path=ActualWidth}"
                                        Loaded="ProgressBar_Loaded">
                                    <Border.Clip>
                                        <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,-16,300,20"/>
                                    </Border.Clip>
                                    <Border x:Name="ProgressFill"
                                            Background="{DynamicResource AccentColor}"
                                            HorizontalAlignment="Left"
                                            Width="{Binding ElementName=ProgressBarBorder, Path=ActualWidth}"
                                            RenderTransformOrigin="0,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ProgressScale" ScaleX="1"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 状态颜色触发器（仅切换 Fill 颜色，Opacity 继承自 Ellipse 顶层统一配置） -->
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding (pages:LabelStatusHelper.LabelStatus), ElementName=NotifyBorder}" Value="Success">
                        <Setter TargetName="GlowEllipse" Property="Fill" Value="{DynamicResource Success}"/>
                        <Setter TargetName="CoreEllipse" Property="Fill" Value="{DynamicResource Success}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding (pages:LabelStatusHelper.LabelStatus), ElementName=NotifyBorder}" Value="Warning">
                        <Setter TargetName="GlowEllipse" Property="Fill" Value="{DynamicResource Warning}"/>
                        <Setter TargetName="CoreEllipse" Property="Fill" Value="{DynamicResource Warning}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding (pages:LabelStatusHelper.LabelStatus), ElementName=NotifyBorder}" Value="Error">
                        <Setter TargetName="GlowEllipse" Property="Fill" Value="{DynamicResource Error}"/>
                        <Setter TargetName="CoreEllipse" Property="Fill" Value="{DynamicResource Error}"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>