<Page x:Class="PlayVoice.Pages.Preset.DeletePresetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PlayVoice.Pages.Preset"
      xmlns:L="clr-namespace:PlayVoice.Resources.Language"
      xmlns:DropDownList="clr-namespace:PlayVoice.Pages.DropDownList"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/ComboBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>


    <Border Width="176" HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="{DynamicResource AccentColor}"
                BorderThickness="1" 
                CornerRadius="6"
                Padding="0,13">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Style="{StaticResource TextBlockMedium}"
                            Grid.Row="0"
                            Text="{L:Lan 删除预设}"
                            FontSize="16"
                            Margin="0,0,0,10"
                            TextAlignment="Center"/>
            <ComboBox  Width="150"
                        Grid.Row="1"
                        x:Name="PresetComboBox"
                        Style="{StaticResource TransparentComboBoxStyle}"
                        Margin="0,5"
                        Height="35"/>
            <ListBox Tag="Uniform"
                    Width="80"
                    Grid.Row="2"
                    Margin="0,5"
                    Style="{StaticResource HorizontalButtonGroupStyle}"
                    x:Name="ButtonGroupListBox">
                <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                    <TextBlock Text="{L:Lan 删除}"
                                 Style="{StaticResource TextBlockLight}"/>
                </ListBoxItem>
            </ListBox>
        </Grid>
    </Border>
</Page>