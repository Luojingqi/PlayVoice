<Page x:Class="PlayVoice.Pages.Preset.UploadPresetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:L="clr-namespace:PlayVoice.Resources.Language"
    xmlns:DropDownList="clr-namespace:PlayVoice.Pages.DropDownList"
    xmlns:HorizontalList="clr-namespace:PlayVoice.Pages.HorizontalList"
    xmlns:Loading="clr-namespace:PlayVoice.Pages.Loading"
    mc:Ignorable="d" >

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Import.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
            BorderBrush="{DynamicResource AccentColor}"
            BorderThickness="1" 
            CornerRadius="6"
            x:Name="OuterLayerBorder"
>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="20,13" x:Name="ContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Style="{StaticResource TextBlockMedium}"
                            Grid.Row="0"
                            Text="{L:Lan 上传到创意工坊}"
                            FontSize="16"
                            Margin="0,0,0,10"
                            TextAlignment="Center"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DropDownList:DropDownList
                                Grid.Column="0"
                                x:Name="PresetComboBox"
                                Header="{L:Lan 预设}"
                                DropDownWidth="105"
                                Margin="0,1.5"
                                Height="37.5"/>
                    <DropDownList:DropDownList
                                Grid.Column="1"
                                x:Name="VisibleComboBox"
                                Header="{L:Lan 可见}"
                                DropDownWidth="105"
                                Margin="0,1.5"
                                Height="37.5" />
                </Grid>
              
                <HorizontalList:HorizontalList
                            Grid.Row="2"
                            x:Name="TabListBox"
                            Header="{L:Lan 标签}"
                            DropDownWidth="265"
                            Margin="0,1.5"
                            Height="37.5"
                            SelectionMode="Multiple"/>
              
                <Grid Grid.Row="3" Margin="0,1.5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,10,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox Grid.Row="0"
                            Margin="0,0,0,5"                            
                            Style="{StaticResource HorizontalButtonGroupStyle}">
                            <ListBoxItem Style="{StaticResource GroupInputItemStyle}"
                                     Height="45">
                                <TextBox Tag="{L:Lan 为你的资源命名}"
                                     x:Name="ResourceNameInputTextBox"
                                     Style="{StaticResource GroupTextBoxStyle}"
                                     Height="45"
                                     Width="130"
                                     FontSize="13"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalAlignment="Stretch" 
                                     VerticalContentAlignment="Top"/>
                            </ListBoxItem>
                        </ListBox>
                        <ListBox Grid.Row="1"
                            Margin="0,5,0,0"
                            Style="{StaticResource HorizontalButtonGroupStyle}">
                            <ListBoxItem Style="{StaticResource GroupInputItemStyle}"
                                     Height="120">
                                <TextBox Tag="{L:Lan 为你的资源添加描述}"
                                     Height="120"
                                     Width="130"
                                     x:Name="ResourceDescriptionInputTextBox"
                                     Style="{StaticResource GroupTextBoxStyle}"
                                     VerticalAlignment="Stretch" 
                                     VerticalContentAlignment="Top"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="13"/>
                            </ListBoxItem>
                        </ListBox>
                    </Grid>
                    <Grid Grid.Column="1" Margin="5,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Rectangle Stroke="{DynamicResource AccentColor}" 
                                    StrokeThickness="2" 
                                    StrokeDashArray="4 2" 
                                    Fill="Transparent" 
                                    RadiusX="5" 
                                    RadiusY="5"/>
                            <ListBox Margin="2.5" 
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Style="{StaticResource HorizontalButtonGroupStyle}"
                                x:Name="ImageButton">
                                <ListBoxItem Width="150" Height="150" Style="{StaticResource GroupButtonItemStyle}">
                                    <Grid Margin="0,7.5">
                                        <Image Source="{StaticResource ImportIcon}" 
                                           Width="25" 
                                           Height="25"
                                           Grid.Row="0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,30"/>
                                        <TextBlock
                                            Style="{StaticResource TextBlockLight}"
                                            Text="{L:Lan 放入预览图}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,13,0,0"/>
                                        <TextBlock
                                            Style="{StaticResource TextBlockLight}"
                                            Text="{L:Lan 预览图要求}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,85,0,0"
                                            Width="120"
                                            FontSize="10"
                                            TextWrapping="Wrap"
                                            TextAlignment="Center"/>
                                    </Grid>
                                </ListBoxItem>
                            </ListBox>
                            <Image x:Name="BgImage" Width="150" Height="150" Margin="2.5"/>
                            <Button Margin="0,5,5,0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Content="╳"
                                FontSize="15"
                                Width="25" Height="25"
                                x:Name="ImageCloseButton">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BgLight}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                        <ListBox Grid.Row="1"
                            Width="80"
                            Tag="Uniform"
                            Margin="0,5"
                            Style="{StaticResource HorizontalButtonGroupStyle}"
                            x:Name="ConfirmButton">
                            <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                                <TextBlock Text="{L:Lan 确认}"
                                    Style="{StaticResource TextBlockLight}"/>
                            </ListBoxItem>
                        </ListBox>
                    </Grid>
                </Grid>

            </Grid>


            <Frame Grid.Row="0" Margin="50"
                   x:Name="LoadingPageFrame"/>

            <Border Grid.Row="1"
                      x:Name="ProgressBarBorder"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Background="Transparent"
                      Height="5"
                      CornerRadius="0,0,6,6"
                      ClipToBounds="True"
                      Width="361">
                <Border.Clip>
                    <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,-15,361,20"/>
                </Border.Clip>
                <Border x:Name="ProgressFill"
                      Background="{DynamicResource AccentColor}"
                      HorizontalAlignment="Left"
                      Width="{Binding ElementName=ProgressBarBorder, Path=ActualWidth}"
                      RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="0"/>
                    </Border.RenderTransform>
                </Border>
            </Border>

            <TextBlock Grid.Row="1"
                       x:Name="ProgressText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,5"
                       FontSize="13"
                       Style="{StaticResource TextBlockLight}"/>
        </Grid>
    </Border>
</Page>
