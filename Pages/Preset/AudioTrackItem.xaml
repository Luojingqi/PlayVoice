<UserControl x:Class="PlayVoice.Pages.Preset.AudioTrackItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:L="clr-namespace:PlayVoice.Resources.Language"
             xmlns:AudioVolumeSlider="clr-namespace:PlayVoice.Pages.AudioVolumeSlider"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/Drag.xaml"/>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border x:Name="RowBorder" 
            Background="Transparent"
            Margin="0,5.5"
            Padding="0,0,3,0"
            PreviewMouseLeftButtonDown="RowBorder_PreviewMouseLeftButtonDown">

        <Border.Triggers>
            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1" Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>

            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0" Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Border BorderBrush="{DynamicResource Border}" 
                    BorderThickness="1" 
                    CornerRadius="3" 
                    IsHitTestVisible="False"/>

            <Border x:Name="HoverBorder" 
                    BorderBrush="{DynamicResource AccentColorSecondary}" 
                    BorderThickness="1" 
                    CornerRadius="3" 
                    Opacity="0" 
                    IsHitTestVisible="False"/>

            <Rectangle x:Name="FillBackground" 
                       Fill="{DynamicResource AccentColor}" 
                       Opacity="0.3"
                       RadiusX="3" RadiusY="3"
                       RenderTransformOrigin="0,0">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="BackgroundScale" ScaleX="0" ScaleY="1"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0"
                            Style="{StaticResource HorizontalButtonGroupStyle}"
                            x:Name="CheckBoxListBox">
                        <ListBoxItem Style="{StaticResource GroupButtonItemStyle}" Padding="5,0">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="19" Height="19"
                                        Stroke="{DynamicResource AccentColor}"
                                        Fill="Transparent"
                                        StrokeThickness="1.5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                <Ellipse Width="8" Height="8"
                                        Fill="{DynamicResource AccentColor}"
                                        x:Name="SelectCenterPoint"
                                         Visibility="Collapsed"/>
                            </Grid>
                        </ListBoxItem>
                    </ListBox>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="DragHandle"
                                Background="Transparent" Grid.Column="0"
                                PreviewMouseLeftButtonDown="DragHandle_MouseDown"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="30"
                                Margin="0,0,10,0"
                                Padding="10"
                                Cursor="SizeNS">
                            <Image Source="{StaticResource DragIcon}"/>
                        </Border>
                        <TextBlock Text="{Binding Header}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Grid.Column="1"/>
                    </Grid>

                    <AudioVolumeSlider:AudioVolumeSlider 
                                        Grid.Column="2"
                                        x:Name="VolumeSlider" 
                                        Value="{Binding VolumeSliderValue, Mode=TwoWay}"/>
                    <TextBlock Grid.Column="3" Text="{Binding SubHeader0}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"  Width="60" Margin="5,0"/>
                    <TextBlock Grid.Column="4" Text="{Binding SubHeader1}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"  Width="60" Margin="5,0"/>
                    <ListBox Grid.Column="5"
                            Style="{StaticResource HorizontalButtonGroupStyle}"
                            x:Name="KeyboardKeyListBox"
                            Width="96">
                        <ListBoxItem Style="{StaticResource GroupInputItemStyle}">
                            <TextBox Tag="{L:Lan 输入按键}"
                                     Text="{Binding Hotkey}"
                                     x:Name="KeyboardKeyInputTextBox"
                                     Style="{StaticResource GroupTextBoxStyle}"
                                     GotFocus="KeyboardKeyInputTextBox_GotFocus"
                                     LostFocus="KeyboardKeyInputTextBox_LostFocus"
                                     InputMethod.IsInputMethodEnabled="False"/>
                        </ListBoxItem>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>