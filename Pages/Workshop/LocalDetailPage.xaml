<UserControl x:Class="PlayVoice.Pages.Workshop.LocalDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PlayVoice.Pages.Workshop"
      xmlns:L="clr-namespace:PlayVoice.Resources.Language"
      mc:Ignorable="d"
      x:Name="self">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Copy.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Folder.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="0"
                    Stroke="{DynamicResource AccentColor}" 
                    StrokeThickness="2" 
                    StrokeDashArray="4 2" 
                    Fill="Transparent" 
                    RadiusX="5" 
                    RadiusY="5"
                    Width="160"
                    Height="160" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"/>
            <Border Grid.Column="0" CornerRadius="5" ClipToBounds="True" Height="146" Width="146" Background="{DynamicResource BgLight}">
                <Image  x:Name="BgImage"  
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"/>
            </Border>

            <Border Grid.Column="1">
                <Grid>
                    <Border Margin="0,5" Grid.Row="1">
                        <TextBlock Style="{StaticResource TextBlockMedium}"
                                        x:Name="ItemTitle" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Top"
                                        FontSize="15"/>
                    </Border>
                </Grid>
            </Border>


            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Margin="0.25,1.5,0.25,1" Grid.Row="0" 
                    Style="{StaticResource HorizontalButtonGroupStyle}"
                    x:Name="FoldUpButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                                Text=">>>" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>

                <ListBox Margin="0.25,2.5" Grid.Row="1" 
                    Style="{StaticResource HorizontalButtonGroupStyle}"
                    x:Name="SubscribeButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                                Text="{L:Lan 订阅按钮}" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>
                <ListBox Margin="0.25,2.5" Grid.Row="1" 
                    Style="{StaticResource HorizontalButtonGroupStyle}"
                    x:Name="UnSubscribeButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                            Text="{L:Lan 取消订阅按钮}" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,8,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="CheckBoxListBox">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}" Padding="5,0">
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="19" Height="19"
                                    Stroke="{DynamicResource AccentColor}"
                                    Fill="Transparent"
                                    StrokeThickness="1.5"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"/>
                            <Ellipse Width="8" Height="8"
                                    Fill="{DynamicResource AccentColor}"
                                    x:Name="SelectCenterPoint"
                                     Visibility="Collapsed"/>
                        </Grid>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}" Padding="3.5" ToolTip="{L:Lan 复制}">
                        <Image Source="{StaticResource CopyIcon}"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}" Padding="6.5" ToolTip="{L:Lan 文件资源浏览器}">
                        <Image Source="{StaticResource FolderIcon}"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ListBoxItem>
                </ListBox>

                <TextBlock Grid.Column="1" 
                           Text="{L:Lan 名称}"  
                           Style="{StaticResource TextBlockMedium}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Padding="0,0,30,0"/>
                <TextBlock Grid.Column="2" 
                           Text="{L:Lan 时长}"
                           Style="{StaticResource TextBlockMedium}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0"/>
                <TextBlock Grid.Column="3" 
                           Text="{L:Lan 大小}" 
                           Style="{StaticResource TextBlockMedium}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="5,0"/>
            </Grid>

            <ListBox Grid.Row="1" 
                     x:Name="AudioListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <local:LocalDetailPageItem/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
