<UserControl x:Class="PlayVoice.Pages.Workshop.TablePageItem"
             x:Name="self"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlayVoice.Pages.Workshop"
             mc:Ignorable="d"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:L="clr-namespace:PlayVoice.Resources.Language"
             MouseLeftButtonUp="OnMouseLeftButtonUp">


    <UserControl.Resources>
        <sys:Double x:Key="ScalePressed">0.93</sys:Double>
        <sys:Double x:Key="ScaleNormal">1.0</sys:Double>
        <sys:Double x:Key="OpacityPressed">0.75</sys:Double>
        <sys:Double x:Key="OpacityNormal">1.0</sys:Double>
        <Duration x:Key="TimePressDuration">0:0:0.06</Duration>
        <Duration x:Key="TimeReboundDuration">0:0:0.35</Duration>
    </UserControl.Resources>

    <UserControl.Template>
        <ControlTemplate TargetType="local:TablePageItem">
            <Grid x:Name="RootGrid" Margin="8" Background="Transparent"
                  Height="{Binding RelativeSource={RelativeSource Self}, Path=ActualWidth}">

                <Grid x:Name="AnimationContainer" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="AnimatedScale" ScaleX="1" ScaleY="1"/>
                    </Grid.RenderTransform>

                    <Border x:Name="MainBorder" 
                            Background="Black" 
                            CornerRadius="2"
                            BorderThickness="3.5"
                            BorderBrush="Transparent">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Image x:Name="BgImage" Grid.Row="0" Stretch="Uniform" 
                                   Source="{Binding ItemImage, ElementName=self}"/>

                            <Border Background="{DynamicResource Border}" 
                                    Opacity="0.5"
                                    Grid.Row="0" 
                                    VerticalAlignment="Bottom" 
                                    Height="30"/>

                            <TextBlock Grid.Row="0" 
                                       Text="{Binding ItemTitle, ElementName=self}" 
                                       Style="{StaticResource TextBlockLight}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Bottom"
                                       FontSize="12"
                                       Opacity="1"
                                       Padding="2,3"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Margin="20">
                    <local:CircularProgressBar x:Name="LoadingBar"/>
                </Border>

                <TextBlock Style="{StaticResource TextBlockLight}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           x:Name="LoadFailedText"
                           Visibility="Hidden"/>
            </Grid>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentColorSecondary}"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>

                <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleX" To="{StaticResource ScalePressed}" Duration="{StaticResource TimePressDuration}"/>
                            <DoubleAnimation Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleY" To="{StaticResource ScalePressed}" Duration="{StaticResource TimePressDuration}"/>
                            <DoubleAnimation Storyboard.TargetName="AnimationContainer" Storyboard.TargetProperty="Opacity" To="{StaticResource OpacityPressed}" Duration="{StaticResource TimePressDuration}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonUp">
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                        <Storyboard>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleX">
                                <LinearDoubleKeyFrame Value="{StaticResource ScalePressed}" KeyTime="0:0:0.06"/>
                                <EasingDoubleKeyFrame Value="{StaticResource ScaleNormal}" KeyTime="0:0:0.41">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleY">
                                <LinearDoubleKeyFrame Value="{StaticResource ScalePressed}" KeyTime="0:0:0.06"/>
                                <EasingDoubleKeyFrame Value="{StaticResource ScaleNormal}" KeyTime="0:0:0.41">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AnimationContainer" Storyboard.TargetProperty="Opacity">
                                <LinearDoubleKeyFrame Value="{StaticResource OpacityPressed}" KeyTime="0:0:0.06"/>
                                <LinearDoubleKeyFrame Value="{StaticResource OpacityNormal}" KeyTime="0:0:0.41"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <EventTrigger RoutedEvent="UIElement.MouseLeave">
                    <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleX" To="{StaticResource ScaleNormal}" Duration="{StaticResource TimeReboundDuration}"/>
                            <DoubleAnimation Storyboard.TargetName="AnimatedScale" Storyboard.TargetProperty="ScaleY" To="{StaticResource ScaleNormal}" Duration="{StaticResource TimeReboundDuration}"/>
                            <DoubleAnimation Storyboard.TargetName="AnimationContainer" Storyboard.TargetProperty="Opacity" To="{StaticResource OpacityNormal}" Duration="{StaticResource TimeReboundDuration}"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
