<UserControl x:Class="PlayVoice.Pages.Workshop.CircularProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" >
    <Viewbox>
        <Grid Width="100" Height="100">
            <Path Stroke="{DynamicResource BgMediumInvert}" StrokeThickness="10" Opacity="0.77"
                  Data="M 50,5 A 45,45 0 1 1 49.99,5 Z" />

            <Path x:Name="ProgressPath" Stroke="{DynamicResource AccentColor}" StrokeThickness="10" 
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round" Opacity="0.9"/>

            <TextBlock x:Name="PercentText" Text="0%" Style="{StaticResource TextBlockHeavy}"
                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                       FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BgDark}"/>
        </Grid>
    </Viewbox>
</UserControl>