<UserControl x:Class="PlayVoice.Pages.Workshop.DetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PlayVoice.Pages.Workshop"
             xmlns:L="clr-namespace:PlayVoice.Resources.Language"
             mc:Ignorable="d"
             x:Name="self">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0"
                Stroke="{DynamicResource AccentColor}" 
                StrokeThickness="2" 
                StrokeDashArray="4 2" 
                Fill="Transparent" 
                RadiusX="5" 
                RadiusY="5"
                Width="160"
                Height="160" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"/>

            <Border Grid.Column="0" CornerRadius="5" ClipToBounds="True" Height="146" Width="146" Background="{DynamicResource BgLight}">
                <Image x:Name="BgImage"  
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"/>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Margin="0.25,1.5,0.25,1" Grid.Row="0" 
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="FoldUpButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                                    Text=">>>" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>

                <ListBox Margin="0.25,2.5" Grid.Row="1" 
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="SubscribeButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                                Text="{L:Lan 订阅按钮}" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>
                <ListBox Margin="0.25,2.5" Grid.Row="1" 
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="UnSubscribeButton" HorizontalAlignment="Center">
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock Style="{StaticResource TextBlockHeavy}"
                                Text="{L:Lan 取消订阅按钮}" Foreground="{DynamicResource AccentColor}"/>
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Grid>

        <Border Margin="0,3" Grid.Row="1">
            <TextBlock Style="{StaticResource TextBlockMedium}"
                       x:Name="ItemTitle"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Top"
                       FontSize="14"/>
        </Border>

        <ListBox Grid.Row="2" 
                x:Name="AudioListBox"
                Background="Transparent"
                BorderThickness="0"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <local:DetailPageItem />
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Border Grid.Row="2" 
          BorderBrush="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            </Grid>
        </Border>
    </Grid>

</UserControl>
