<Page x:Class="PlayVoice.Pages.Setting.SystemSettingsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:PlayVoice.Pages.Setting"
        xmlns:L="clr-namespace:PlayVoice.Resources.Language"
        xmlns:DropDownList="clr-namespace:PlayVoice.Pages.DropDownList"
        xmlns:ToggleSwitchButton="clr-namespace:PlayVoice.Pages.ToggleSwitchButton"
        xmlns:HorizontalList="clr-namespace:PlayVoice.Pages.HorizontalList"
        xmlns:pages="clr-namespace:PlayVoice.Pages"
        xmlns:AudioVolumeSlider="clr-namespace:PlayVoice.Pages.AudioVolumeSlider"
        mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/PageBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Button.xaml"/>
                <ResourceDictionary Source="/Resources/Style/ListBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <HeaderedContentControl Style="{StaticResource PageBoxStyle}"
                            Header="{L:Lan 系统设置}">
        <Grid Margin="2.5,2.5,2.5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ToggleSwitchButton:ToggleSwitchButton
                     Grid.Row="0"
                     x:Name="RunToggle"
                     Header="{L:Lan 运行}"
                     ButtonWidth="80"
                     Margin="0,1.5"
                     Padding="0,2.2"
                     Height="42.5"/>
            <ToggleSwitchButton:ToggleSwitchButton
                     Grid.Row="1"
                     x:Name="EarAudioToggle"
                     Header="{L:Lan 耳返_Audio}"
                     ButtonWidth="80"
                     Margin="0,1.5"
                     Padding="0,2.2"
                     Height="42.5"/>
            <ToggleSwitchButton:ToggleSwitchButton
                     Grid.Row="2"
                     x:Name="EarInToggle"
                     Header="{L:Lan 耳返_In}"
                     ButtonWidth="80"
                     Margin="0,1.5"
                     Padding="0,2.2"
                     Height="42.5"/>
            <ToggleSwitchButton:ToggleSwitchButton
                     Grid.Row="3"
                     x:Name="AutoMuteToggle"
                     Header="{L:Lan 自动闭麦}"
                     ButtonWidth="80"
                     Margin="0,1.5"
                     Padding="0,2.2"
                     Height="42.5"/>
            <DropDownList:DropDownList
                    Grid.Row="4"
                    x:Name="PresetComboBox"
                    Header="{L:Lan 预设}"
                    DropDownWidth="130"
                    Margin="0,1.5"
                    Height="37.5"/>
            <DropDownList:DropDownList
                    Grid.Row="5"
                    x:Name="LanguageComboBox"
                    Header="{L:Lan 语言}"
                    DropDownWidth="130"
                    Margin="0,1.5"
                    Height="37.5"/>
            <HorizontalList:HorizontalList
                    Grid.Row="6"
                    x:Name="StyleListBox"
                    Header="{L:Lan 样式}"
                    DropDownWidth="130"
                    Margin="0,1.5"
                    Height="37.5"/>
            <Grid Grid.Row="7"
                  Margin="0,1.5"
                  Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock  Grid.Column="0"
                            FontSize="16"
                            Text="{L:Lan 响度归一化测试}" 
                            Style="{StaticResource TextBlockLight}"
                            VerticalAlignment="Center" 
                            Margin="13.5,0,0,0" 
                            HorizontalAlignment="Left"
                            TextAlignment="Left"/>
                <ListBox  Grid.Column="1"
                        Width="130"
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="VolumeTestGroupListBox"
                        Tag="Uniform"
                        HorizontalAlignment="Right"
                          VerticalAlignment="Center" >
                    <ListBoxItem Style="{StaticResource GroupButtonItemStyle}">
                        <TextBlock x:Name="VolumeTestIcon" 
                            Text="{L:Lan 测试}" Style="{StaticResource TextBlockLight}"/>
                    </ListBoxItem>
                    <!--<ListBoxItem Style="{StaticResource GroupInputItemStyle}">
                        <TextBox x:Name="VolumeTestTextBox" Text="70" Style="{StaticResource GroupTextBoxStyle}"/>
                    </ListBoxItem>-->
                </ListBox>

            </Grid>


            <Grid Grid.Row="8" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                            Margin="13.5,0,0,0"
                            FontSize="16"
                            Style="{StaticResource TextBlockLight}"
                            Text="{L:Lan 音频输出音量}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"/>
                <AudioVolumeSlider:AudioVolumeSlider
                            x:Name="AudioOutVolumeSlider"
                            Grid.Column="1"
                            Width="168"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
            </Grid>
            <Grid Grid.Row="9" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                            Margin="13.5,0,0,0"
                            FontSize="16"
                            Style="{StaticResource TextBlockLight}"
                            Text="{L:Lan 音频耳返音量}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"/>
                <AudioVolumeSlider:AudioVolumeSlider
                            x:Name="AudioEarVolumeSlider"
                            Grid.Column="1"
                            Width="168"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="10" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                            Margin="13.5,0,0,0"
                            FontSize="16"
                            Style="{StaticResource TextBlockLight}"
                            Text="{L:Lan 麦克风输入音量}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"/>
                <AudioVolumeSlider:AudioVolumeSlider
                            x:Name="MicrophoneVolumeSlider"
                            Grid.Column="1"
                            Width="168"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="11" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                            Margin="13.5,0,0,0"
                            FontSize="16"
                            Style="{StaticResource TextBlockLight}"
                            Text="{L:Lan 全局音量}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"/>
                <AudioVolumeSlider:AudioVolumeSlider
                            x:Name="GlobalVolumeSlider"
                            Grid.Column="1"
                            Width="168"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="12" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DropDownList:DropDownList
                            Grid.Column="0"
                            x:Name="BeforePlayingComboBox"
                            Header="{L:Lan 播放前}"
                            DropDownWidth="80"/>
                <ListBox Grid.Column="1" Margin="10,0,0,0"
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="KeyboardKeyListBox0"
                        HorizontalAlignment="Right"
                        Width="96">
                    <ListBoxItem Style="{StaticResource GroupInputItemStyle}">
                        <TextBox Tag="{L:Lan 输入按键}"
                                 x:Name="KeyboardKeyInputTextBox0"
                                 Style="{StaticResource GroupTextBoxStyle}"
                                 GotFocus="KeyboardKeyInputTextBox0_GotFocus"
                                 LostFocus="KeyboardKeyInputTextBox0_LostFocus"
                                 InputMethod.IsInputMethodEnabled="False"/>
                    </ListBoxItem>
                </ListBox>
            </Grid>
            <Grid Grid.Row="13" Margin="0,1.5" Height="37.5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <DropDownList:DropDownList
                            Grid.Column="0"
                            x:Name="AfterPlayingComboBox"
                            Header="{L:Lan 播放后}"
                            DropDownWidth="80"/>
                <ListBox Grid.Column="1" Margin="10,0,0,0"
                        Style="{StaticResource HorizontalButtonGroupStyle}"
                        x:Name="KeyboardKeyListBox1"
                        HorizontalAlignment="Right"
                        Width="96">
                    <ListBoxItem Style="{StaticResource GroupInputItemStyle}">
                        <TextBox Tag="{L:Lan 输入按键}"
                                 x:Name="KeyboardKeyInputTextBox1"
                                 Style="{StaticResource GroupTextBoxStyle}"
                                 GotFocus="KeyboardKeyInputTextBox1_GotFocus"
                                 LostFocus="KeyboardKeyInputTextBox1_LostFocus"
                                 InputMethod.IsInputMethodEnabled="False"/>
                    </ListBoxItem>
                </ListBox>
            </Grid>



            <Border Grid.Row="14" Margin="0,1.5,0,0"/>
        </Grid>
    </HeaderedContentControl>
</Page>
