<Page x:Class="PlayVoice.Pages.Setting.SettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:L="clr-namespace:PlayVoice.Resources.Language"
      xmlns:Hyperlink="clr-namespace:PlayVoice.Pages.Hyperlink"
      xmlns:Setting="clr-namespace:PlayVoice.Pages.Setting"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/Button.xaml"/>
                <ResourceDictionary Source="/Resources/Style/PageBox.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Github.xaml"/>
                <ResourceDictionary Source="/Resources/Style/Steam.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource AccentColor}"
                BorderThickness="0,3,0,0"/>
        
        
        <Border Height="50" Grid.Row="1" Background="{DynamicResource BgMedium}" BorderThickness="2,0,0,0" CornerRadius="0,0,5,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{L:Lan 设置}" VerticalAlignment="Center" HorizontalAlignment="Left" Padding="20,0,0,0"
                    Style="{StaticResource TextBlockHeavy}" FontSize="22" Grid.Column="0"/>
                <Border Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource ImageButtonStyle}"
                            Content="{StaticResource SteamIcon}"
                            Hyperlink:HyperlinkBehavior.Url="https://store.steampowered.com"
                            ToolTip="{L:Lan 去Steam}" 
                            Width="36" Height="36"
                            Grid.Column="0"/>
                        <Button Style="{StaticResource ImageButtonStyle}"
                            Content="{StaticResource GithubIcon}"
                            Hyperlink:HyperlinkBehavior.Url="https://github.com/Luojingqi/PlayVoice"
                            ToolTip="{L:Lan 去Github}" 
                            Width="36" Height="36"
                            Grid.Column="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="10,10,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid x:Name="ContentGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="0,0,5,5">
                        <VirtualizingStackPanel x:Name="ContentLeftPanel">
                            <Border Margin="0,0,0,10">
                                <Frame Source="/Pages/Setting/SoundCardBindingPage.xaml"/>
                            </Border>

                            <Border Margin="0,0,0,10">
                                <Frame Source="/Pages/Setting/SystemSettingsPage.xaml"/>
                            </Border>
                        </VirtualizingStackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="5,0,5,5">
                        <VirtualizingStackPanel x:Name="ContentRightPanel">
                            <Border Margin="0,0,0,10">
                                <Frame Source="/Pages/Setting/VirtualSoundCardInstallationPage.xaml"/>
                            </Border>

                            <Border Margin="0,0,0,10">
                                <Frame Source="/Pages/Setting/TutorialPage.xaml"/>
                            </Border>

                            <Border Margin="0,0,0,10">
                                <Frame Source="/Pages/Setting/AboutPage.xaml"/>
                            </Border>
                        </VirtualizingStackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
