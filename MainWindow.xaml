<Window x:Class="PlayVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Sidebar="clr-namespace:PlayVoice.Pages.Sidebar"
        xmlns:L="clr-namespace:PlayVoice.Resources.Language"
        xmlns:NotificationPanel="clr-namespace:PlayVoice.Pages.NotificationPanel"
        xmlns:LevelBar="clr-namespace:PlayVoice.Pages.LevelBar"
        Height="700" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown"
        Focusable="True"
        Title="Play Voice"
        Icon="/Resources/Style/PlayVoice.png">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Style/Button.xaml"/>
                <ResourceDictionary Source="/Resources/Style/PageBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="SidebarItemTemplate">
                <Border Padding="12,10" CornerRadius="8">
                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"/>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource BgDark}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BgLight}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border  Grid.Row="0" CornerRadius="12,12,0,0" Background="{DynamicResource Title}">
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- 可拖拽的标题区域 -->
                    <Border  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                        Background="Transparent"
                        CornerRadius="12,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="1"
                                Text="{L:Lan 软件名称}"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Foreground="{DynamicResource AccentColor}"
                                FontFamily="{StaticResource FontLight}"/>
                        </Grid>
                    </Border>


                    <!-- 窗口控制按钮 -->
                    <Border Grid.Column="1" Padding="0,0,0,0" CornerRadius="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="MinimizeButton" Grid.Column="0"
                                Content="─" Click="MinimizeButton_OnClick" Style="{StaticResource NavButtonStyle}"
                                FontSize="14"/>
                            <Button x:Name="MaximizeButton" Grid.Column="1"
                                Content="☐" Click="MaximizeButton_OnClick" Style="{StaticResource NavButtonStyle}"
                                FontSize="14"/>
                            <Button x:Name="CloseButton" Grid.Column="2"
                                Content="╳"  Click="CloseButton_OnClick" Style="{StaticResource CloseButtonStyle}"
                                FontSize="14"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <!-- ========== 主体区域 ========== -->
            <Grid Grid.Row="1" Cursor="">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="175"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧导航栏 -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgMedium}"
                        CornerRadius="0,0,0,12">
                    <Sidebar:SidebarControl x:Name="Sidebar"
                        ItemsSource="{Binding MenuItems}"
                        SelectedItem="{Binding SelectedMenu, Mode=TwoWay}"
                        ItemTemplate="{StaticResource SidebarItemTemplate}"/>
                </Border>

                <Border Grid.Column="0" VerticalAlignment="Bottom" 
                        Margin="0,0,0,0"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="0,3">
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       Style="{StaticResource TextBlockLight}"
                                       Text="{L:Lan 音频}"
                                       Foreground="{DynamicResource AccentColor}"
                                       FontSize="13"
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center"
                                       Width="15"
                                       Margin="3,0"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <LevelBar:LevelBar Grid.Row="0" Margin="2,2" x:Name="AL"/>
                                    <LevelBar:LevelBar Grid.Row="1" Margin="2,2" x:Name="AR"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource AccentColor}" 
                                BorderThickness="1"
                                Height="1"
                                Margin="0,3.5,55,3.5"/>
                        
                        <Border Grid.Row="2"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                       Style="{StaticResource TextBlockLight}"
                                       Text="{L:Lan 输入}"
                                       Foreground="{DynamicResource AccentColor}"
                                       FontSize="13"
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center"
                                       Width="15"
                                       Margin="3,0"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <LevelBar:LevelBar Grid.Row="0" Margin="2,2" x:Name="IL"/>
                                    <LevelBar:LevelBar Grid.Row="1" Margin="2,2" x:Name="IR"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                BorderBrush="{DynamicResource AccentColor}" 
                                BorderThickness="1"
                                Height="1"
                                Margin="0,3.5,55,3.5"/>

                        <Border Grid.Row="4"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                   Style="{StaticResource TextBlockLight}"
                                   Text="{L:Lan 输出}"
                                   Foreground="{DynamicResource AccentColor}"
                                   FontSize="13"
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center"
                                   Width="15"
                                   Margin="3,0"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <LevelBar:LevelBar Grid.Row="0" Margin="2,2" x:Name="OL"/>
                                    <LevelBar:LevelBar Grid.Row="1" Margin="2,2" x:Name="OR"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 右侧内容区 -->
                <Border Grid.Column="1"
                        Background="{DynamicResource BgDark}">
                    <Grid>
                        <Frame x:Name="ContentFrame"
                            Grid.Column="1"
                            NavigationUIVisibility="Hidden"/>

                        <NotificationPanel:NotificationPanel 
                            x:Name="NotificationPanel"
                            Panel.ZIndex="100"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>